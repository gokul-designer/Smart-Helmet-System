#include <SoftwareSerial.h>
#include <TinyGPS++.h>

#define HELMET_PIN 2
#define VIBRATION_PIN 3
#define RELAY_PIN 4
#define BUZZER_PIN 5
#define ALCOHOL_PIN A0

SoftwareSerial gpsSerial(6, 7);    // RX, TX
SoftwareSerial gsmSerial(8, 9);    // RX, TX

TinyGPSPlus gps;

const int alcoholThreshold = 400;

String latitude = "";
String longitude = "";

void setup()
{
  pinMode(HELMET_PIN, INPUT_PULLUP);
  pinMode(VIBRATION_PIN, INPUT);
  pinMode(RELAY_PIN, OUTPUT);
  pinMode(BUZZER_PIN, OUTPUT);

  digitalWrite(RELAY_PIN, LOW);
  digitalWrite(BUZZER_PIN, LOW);

  Serial.begin(9600);
  gpsSerial.begin(9600);
  gsmSerial.begin(9600);

  Serial.println("Smart Helmet System Started");
}

void loop()
{
  while (gpsSerial.available())
  {
    gps.encode(gpsSerial.read());
  }

  if (gps.location.isUpdated())
  {
    latitude = String(gps.location.lat(), 6);
    longitude = String(gps.location.lng(), 6);
  }

  bool helmet = digitalRead(HELMET_PIN) == LOW;
  int alcoholValue = analogRead(ALCOHOL_PIN);
  bool accident = digitalRead(VIBRATION_PIN);

  Serial.print("Alcohol: ");
  Serial.println(alcoholValue);

  if (!helmet)
  {
    digitalWrite(RELAY_PIN, LOW);
    beep();
    Serial.println("Helmet Not Worn");
  }
  else if (alcoholValue > alcoholThreshold)
  {
    digitalWrite(RELAY_PIN, LOW);
    beep();
    Serial.println("Alcohol Detected");
  }
  else
  {
    digitalWrite(RELAY_PIN, HIGH);
    digitalWrite(BUZZER_PIN, LOW);
  }

  if (accident == HIGH)
  {
    Serial.println("Accident Detected");
    sendSMS();
    delay(10000);
  }

  delay(500);
}

void beep()
{
  digitalWrite(BUZZER_PIN, HIGH);
  delay(300);
  digitalWrite(BUZZER_PIN, LOW);
}

void sendSMS()
{
  gsmSerial.println("AT");
  delay(1000);

  gsmSerial.println("AT+CMGF=1");
  delay(1000);

  gsmSerial.println("AT+CMGS=\"+911234567890\"");
  delay(1000);

  gsmSerial.print("Emergency!\n");
  gsmSerial.print("Accident Detected.\n");

  if (latitude != "" && longitude != "")
  {
    gsmSerial.print("Location:\n");
    gsmSerial.print("https://maps.google.com/?q=");
    gsmSerial.print(latitude);
    gsmSerial.print(",");
    gsmSerial.println(longitude);
  }
  else
  {
    gsmSerial.println("GPS Location Not Available");
  }

  gsmSerial.write(26);

  delay(5000);
}
